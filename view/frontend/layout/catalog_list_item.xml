<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Override product list item template to add QuickView button -->
        <referenceBlock name="product_list_item" template="Magento_Catalog::product/list/item.phtml">
            <!-- Add QuickView button as direct child (same pattern as wishlist) -->
            <block name="product.quickview.button"
                   as="quickview"
                   template="Panth_QuickView::product/list/buttons.phtml"
                   after="catalog.list.item.wishlist"/>
        </referenceBlock>
    </body>
</page>
