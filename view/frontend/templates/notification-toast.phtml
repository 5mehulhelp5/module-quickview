<div x-data="toastNotification()"
     @show-notification.window="showToast($event.detail.message, $event.detail.type)"
     x-cloak
     style="display: contents;">

    <!-- Toast Container (fixed top-right) -->
    <div class="fixed top-4 right-4 z-50 space-y-2 pointer-events-none"
         style="max-width: 400px;">

        <template x-for="(toast, index) in toasts" :key="toast.id">
            <div x-show="toast.visible"
                 x-transition:enter="transform transition ease-out duration-300"
                 x-transition:enter-start="translate-x-full opacity-0"
                 x-transition:enter-end="translate-x-0 opacity-100"
                 x-transition:leave="transform transition ease-in duration-200"
                 x-transition:leave-start="translate-x-0 opacity-100"
                 x-transition:leave-end="translate-x-full opacity-0"
                 class="pointer-events-auto flex items-start gap-3 px-4 py-3 rounded-lg shadow-2xl backdrop-blur-sm transform hover:scale-105 transition-transform duration-200"
                 :class="{
                     'bg-green-50 border-l-4 border-green-500': toast.type === 'success',
                     'bg-red-50 border-l-4 border-red-500': toast.type === 'error',
                     'bg-yellow-50 border-l-4 border-yellow-500': toast.type === 'warning',
                     'bg-blue-50 border-l-4 border-blue-500': toast.type === 'info'
                 }">

                <!-- Icon -->
                <div class="flex-shrink-0 pt-0.5">
                    <!-- Success Icon -->
                    <template x-if="toast.type === 'success'">
                        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </template>

                    <!-- Error Icon -->
                    <template x-if="toast.type === 'error'">
                        <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </template>

                    <!-- Warning Icon -->
                    <template x-if="toast.type === 'warning'">
                        <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                    </template>

                    <!-- Info Icon -->
                    <template x-if="toast.type === 'info'">
                        <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </template>
                </div>

                <!-- Message -->
                <div class="flex-1 pt-0.5">
                    <p class="text-sm font-medium"
                       :class="{
                           'text-green-800': toast.type === 'success',
                           'text-red-800': toast.type === 'error',
                           'text-yellow-800': toast.type === 'warning',
                           'text-blue-800': toast.type === 'info'
                       }"
                       x-text="toast.message">
                    </p>
                </div>

                <!-- Close Button -->
                <button @click="removeToast(toast.id)"
                        class="flex-shrink-0 rounded-lg p-1 transition-colors duration-200"
                        :class="{
                            'text-green-500 hover:bg-green-100': toast.type === 'success',
                            'text-red-500 hover:bg-red-100': toast.type === 'error',
                            'text-yellow-500 hover:bg-yellow-100': toast.type === 'warning',
                            'text-blue-500 hover:bg-blue-100': toast.type === 'info'
                        }">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>

                <!-- Progress Bar -->
                <div class="absolute bottom-0 left-0 h-1 bg-current opacity-30 rounded-bl"
                     :class="{
                         'text-green-500': toast.type === 'success',
                         'text-red-500': toast.type === 'error',
                         'text-yellow-500': toast.type === 'warning',
                         'text-blue-500': toast.type === 'info'
                     }"
                     :style="`width: ${toast.progress}%; transition: width linear ${toast.duration}ms;`">
                </div>
            </div>
        </template>
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('toastNotification', () => ({
        toasts: [],
        nextId: 1,

        init() {
            // Auto-cleanup old toasts every 5 seconds
            setInterval(() => {
                this.toasts = this.toasts.filter(t => t.visible);
            }, 5000);
        },

        showToast(message, type = 'info', duration = 4000) {
            const toast = {
                id: this.nextId++,
                message: message,
                type: type,
                duration: duration,
                visible: true,
                progress: 100
            };

            this.toasts.push(toast);

            // Start progress animation
            setTimeout(() => {
                toast.progress = 0;
            }, 10);

            // Auto-hide toast after duration
            setTimeout(() => {
                this.removeToast(toast.id);
            }, duration);

            // Limit to 5 toasts
            if (this.toasts.length > 5) {
                this.toasts.shift();
            }
        },

        removeToast(id) {
            const toast = this.toasts.find(t => t.id === id);
            if (toast) {
                toast.visible = false;
                // Remove from array after animation
                setTimeout(() => {
                    this.toasts = this.toasts.filter(t => t.id !== id);
                }, 300);
            }
        }
    }));
});
</script>

<style>
[x-cloak] { display: none !important; }

/* Ensure toasts are above everything */
.z-50 {
    z-index: 9999 !important;
}
</style>
