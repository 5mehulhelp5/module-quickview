$viewId = $block->getRequest()->getParam('id');
$viewRecord = $block->getView($viewId);

if (!$viewRecord) {
    echo '<p>View record not found.</p>';
    return;
}

$productInfo = $block->getProductInfo($viewRecord->getProductId());
$customerInfo = $block->getCustomerInfo($viewRecord->getCustomerId());
$productHistory = $block->getProductViewHistory($viewRecord->getProductId(), 10);

$viewerName = 'Guest';
$viewerType = 'guest';
if ($viewRecord->getCustomerId()) {
    $viewerName = $customerInfo ? $customerInfo['name'] : 'Unknown Customer';
    $viewerType = 'customer';
} elseif ($viewRecord->getVisitorId()) {
    $viewerName = 'Visitor #' . substr($viewRecord->getVisitorId(), 0, 8);
    $viewerType = 'visitor';
}
